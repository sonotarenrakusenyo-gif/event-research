# ============================================================
# イベントリサーチツール 環境変数設定ファイル
# このファイルをコピーして .env という名前で保存し、各値を入力してください
# cp .env.example .env
# ============================================================

# ----------------------------------------
# SerpAPI（Google検索結果を取得）
# ※ Google Custom Search JSON API は新規利用者への提供を終了したため、
#   検索バックエンドとして SerpAPI を使用します。
# 取得先: https://serpapi.com/
#   → 無料登録（無料枠: 月100回検索）
#   → ダッシュボードの「Your Private API Key」をコピー
# ----------------------------------------
SERPAPI_KEY=your_serpapi_key_here

# ----------------------------------------
# Gemini API Key（無料枠利用可能）
# 取得先: https://aistudio.google.com/app/apikey
#   → 「APIキーを作成」ボタンをクリック
# ----------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------------------------------
# Google Sheets 連携（サービスアカウント）
# 設定手順:
#   1. https://console.cloud.google.com/ → APIとサービス → ライブラリ
#      → "Google Sheets API" と "Google Drive API" を有効化
#   2. IAMと管理 → サービスアカウント → サービスアカウントを作成
#   3. 作成したサービスアカウントの「キー」タブ → JSONキーを追加してダウンロード
#   4. ダウンロードしたJSONファイルの内容をすべてコピーして下に貼り付け
#      （改行なし・1行で）
#   5. 書き込み先スプレッドシートの「共有」設定で、
#      サービスアカウントのメール（〜@〜.iam.gserviceaccount.com）を「編集者」として追加
# ----------------------------------------
GS_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# 書き込み先スプレッドシートのURLまたはID
# 例: https://docs.google.com/spreadsheets/d/1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms/edit
GS_SPREADSHEET_ID=your_spreadsheet_url_or_id_here

# Googleドライブ バックアップフォルダID（任意・推奨）
# 手順: Driveでフォルダ作成 → サービスアカウントを「編集者」で共有
# → フォルダURL末尾のIDをコピー（https://drive.google.com/drive/folders/ここがID）
GS_DRIVE_FOLDER_ID=your_drive_folder_id_here
